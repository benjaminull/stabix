# ========================================
# STABIX - Production Environment Variables
# ========================================
# Copia este archivo a .env.production y completa los valores

# ========================================
# DATABASE
# ========================================
POSTGRES_DB=stabix
POSTGRES_USER=stabix
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_123

# ========================================
# DJANGO
# ========================================
# IMPORTANTE: Genera un SECRET_KEY seguro con:
# python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
DJANGO_SECRET_KEY=CHANGE_ME_GENERATE_RANDOM_SECRET_KEY
DJANGO_SETTINGS_MODULE=stabix_backend.settings.prod
DEBUG=0

# Tu dominio o IP del servidor (separados por coma si son múltiples)
# Ejemplo: stabix.com,www.stabix.com,123.456.789.0
ALLOWED_HOSTS=your-domain.com

# URLs permitidas para CORS (separadas por coma)
# Ejemplo: https://stabix.com,https://www.stabix.com
CORS_ALLOWED_ORIGINS=https://your-domain.com

# ========================================
# SSL/HTTPS (Opcional - Caddy lo maneja automáticamente)
# ========================================
# Descomenta estas líneas SOLO si tienes un dominio con SSL configurado
# ENABLE_SSL=True

# ========================================
# DOMAIN & EMAIL (Para Caddy SSL)
# ========================================
# Tu dominio (sin https://)
# Si no tienes dominio aún, usa: :80
DOMAIN=your-domain.com
# Email para certificados SSL de Let's Encrypt
CADDY_EMAIL=admin@your-domain.com

# ========================================
# FRONTEND (Next.js)
# ========================================
# URL de la API (incluye /api al final)
# En producción, usa tu dominio real
NEXT_PUBLIC_API_BASE_URL=https://your-domain.com/api

# Token de Mapbox (obtén uno gratis en https://account.mapbox.com)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token_here

# Configuración de la app
NEXT_PUBLIC_APP_NAME=Stabix
NEXT_PUBLIC_APP_URL=https://your-domain.com

# WebSocket habilitado
NEXT_PUBLIC_ENABLE_WEBSOCKET=true

# ========================================
# EMAIL (Opcional - para notificaciones)
# ========================================
# Ejemplo con Gmail:
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=noreply@your-domain.com

# ========================================
# NOTAS IMPORTANTES
# ========================================
# 1. NO subas este archivo a Git con valores reales
# 2. Usa contraseñas fuertes (mínimo 20 caracteres)
# 3. El DJANGO_SECRET_KEY debe ser único y aleatorio
# 4. Si usas un dominio, Caddy manejará SSL automáticamente
# 5. Si solo usas IP, usa DOMAIN=:80 y no habilites SSL
